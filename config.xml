<?xml version="1.0" encoding="UTF-8"?>
<Configuration>

    <!--
        ClientShare (required)
        UNC or local path to the folder that contains ccmsetup.exe.
        When the client is healthy, the script caches ccmsetup.exe from
        C:\Windows\CCMSetup into this folder for use during future repairs.
    -->
    <ClientShare>C:\ProgramData\ClientHealth</ClientShare>

    <!--
        ClientInstallProperties (optional)
        Space-separated properties passed directly to ccmsetup.exe on install.
        Leave the element empty if no extra properties are needed.
        Example: SMSSITECODE=P01 SMSMP=sccm.contoso.com
    -->
    <ClientInstallProperties>SMSSITECODE=TB1</ClientInstallProperties>

    <!--
        LogPath (optional)
        Directory where the timestamped log file is written.
        Defaults to C:\EnturixClientHealth if omitted or left empty.
    -->
    <LogPath>C:\Windows\Logs\SCCMClientHealth</LogPath>

    <!--
        Checks (optional)
        Set any check to false to skip it entirely.
        All checks default to true if the element is missing or empty.

        TaskSequence    - Exit immediately if a Task Sequence is running (recommended: true)
        CcmExecService  - Verify the SMS Agent Host service is running
        CcmSDF          - Verify >= 7 .sdf database files exist in the CCM directory
        CcmSQLCELog     - Detect ongoing CCM database corruption via CcmSQLCE.log
        WMIHealth       - Verify WMI repository consistency and Win32_ComputerSystem access
        CcmWMIClass     - Verify the SMS_Client class is accessible in root/ccm
        ProvisioningMode- Detect and auto-remediate clients stuck in Provisioning Mode
        CCMClientSDK    - Verify root\ccm\ClientSDK is accessible (Software Center data layer)
    -->
    <Checks>
        <TaskSequence>true</TaskSequence>
        <CcmExecService>true</CcmExecService>
        <CcmSDF>true</CcmSDF>
        <CcmSQLCELog>true</CcmSQLCELog>
        <WMIHealth>true</WMIHealth>
        <CcmWMIClass>true</CcmWMIClass>
        <ProvisioningMode>true</ProvisioningMode>
        <CCMClientSDK>true</CCMClientSDK>
    </Checks>

</Configuration>
